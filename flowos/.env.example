# ─────────────────────────────────────────────────────────────────────────────
# FlowOS — Environment Variable Reference
#
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# The .env file is loaded automatically by Docker Compose and by
# pydantic-settings (via python-dotenv) in the application code.
#
# Variable naming conventions:
#   - Infrastructure variables use the service name as a prefix
#     (KAFKA_, TEMPORAL_, DATABASE_, S3_)
#   - Application variables use the APP_ prefix
#   - Agent identity variables use the FLOWOS_ prefix
#   - Optional variables have a sensible default shown in the comment
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# APPLICATION
# ═════════════════════════════════════════════════════════════════════════════

# Runtime environment: development | staging | production
APP_ENV=development

# Enable debug mode (verbose logging, stack traces in API responses)
APP_DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_LOG_LEVEL=INFO

# Secret key used for JWT signing and other cryptographic operations.
# MUST be changed in staging and production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change-me-in-production-use-a-long-random-string

# JWT access token expiry in minutes (default: 60)
APP_ACCESS_TOKEN_EXPIRE_MINUTES=60

# JWT refresh token expiry in days (default: 30)
APP_REFRESH_TOKEN_EXPIRE_DAYS=30

# Root directory for all agent workspaces (default: /flowos/workspaces)
APP_WORKSPACE_ROOT=/flowos/workspaces


# ═════════════════════════════════════════════════════════════════════════════
# KAFKA — Central Event Bus
# ═════════════════════════════════════════════════════════════════════════════

# Comma-separated list of Kafka broker addresses.
# Local development (Docker Compose internal network):
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Inside Docker Compose network (service-to-service):
# KAFKA_BOOTSTRAP_SERVERS=kafka:9093

# Security protocol: PLAINTEXT | SSL | SASL_PLAINTEXT | SASL_SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# SASL authentication (required when KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT or SASL_SSL)
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=your-kafka-username
# KAFKA_SASL_PASSWORD=your-kafka-password

# SSL/TLS (required when KAFKA_SECURITY_PROTOCOL=SSL or SASL_SSL)
# KAFKA_SSL_CA_LOCATION=/path/to/ca.pem
# KAFKA_SSL_CERTIFICATE_LOCATION=/path/to/client.pem
# KAFKA_SSL_KEY_LOCATION=/path/to/client.key

# Producer settings
# KAFKA_PRODUCER_ACKS=all
# KAFKA_PRODUCER_RETRIES=5
# KAFKA_PRODUCER_RETRY_BACKOFF_MS=500
# KAFKA_PRODUCER_COMPRESSION_TYPE=snappy

# Consumer settings
# KAFKA_CONSUMER_GROUP_ID=flowos-default
# KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
# KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false


# ═════════════════════════════════════════════════════════════════════════════
# TEMPORAL — Durable Workflow Orchestration
# ═════════════════════════════════════════════════════════════════════════════

# Temporal server hostname (default: localhost)
TEMPORAL_HOST=localhost
# Inside Docker Compose network:
# TEMPORAL_HOST=temporal

# Temporal gRPC frontend port (default: 7233)
TEMPORAL_PORT=7233

# Temporal namespace (default: default)
TEMPORAL_NAMESPACE=default

# Temporal task queue name (default: flowos-main)
TEMPORAL_TASK_QUEUE=flowos-main

# TLS for Temporal (production)
# TEMPORAL_TLS_ENABLED=false
# TEMPORAL_TLS_CERT_PATH=/path/to/client.pem
# TEMPORAL_TLS_KEY_PATH=/path/to/client.key
# TEMPORAL_TLS_CA_PATH=/path/to/ca.pem

# Worker concurrency
# TEMPORAL_MAX_CONCURRENT_ACTIVITIES=100
# TEMPORAL_MAX_CONCURRENT_WORKFLOWS=500


# ═════════════════════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL Metadata Store
# ═════════════════════════════════════════════════════════════════════════════

# Async SQLAlchemy URL (used by the application at runtime).
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://flowos:flowos_secret@localhost:5432/flowos
# Inside Docker Compose network:
# DATABASE_URL=postgresql+asyncpg://flowos:flowos_secret@postgres:5432/flowos

# Synchronous SQLAlchemy URL (used by Alembic migrations).
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_SYNC_URL=postgresql://flowos:flowos_secret@localhost:5432/flowos
# Inside Docker Compose network:
# DATABASE_SYNC_URL=postgresql://flowos:flowos_secret@postgres:5432/flowos

# Connection pool settings
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
# DATABASE_POOL_TIMEOUT=30
# DATABASE_POOL_RECYCLE=3600
# DATABASE_ECHO=false


# ═════════════════════════════════════════════════════════════════════════════
# S3 / MINIO — Artifact & Snapshot Object Storage
# ═════════════════════════════════════════════════════════════════════════════

# S3-compatible endpoint URL.
# For local MinIO (Docker Compose):
S3_ENDPOINT=http://localhost:9000
# Inside Docker Compose network:
# S3_ENDPOINT=http://minio:9000
# For AWS S3 (leave empty to use the default AWS endpoint):
# S3_ENDPOINT=

# S3 access key ID (MinIO root user or AWS access key)
S3_ACCESS_KEY=flowos_minio

# S3 secret access key (MinIO root password or AWS secret key)
S3_SECRET_KEY=flowos_minio_secret

# S3 region (default: us-east-1; MinIO ignores this but boto3 requires it)
S3_REGION=us-east-1

# Bucket names (created automatically by minio-init on first run)
S3_BUCKET_ARTIFACTS=artifacts
S3_BUCKET_SNAPSHOTS=snapshots
S3_BUCKET_CHECKPOINTS=checkpoints
S3_BUCKET_LOGS=logs

# Force path-style addressing (required for MinIO; set false for AWS S3)
S3_USE_PATH_STYLE=true


# ═════════════════════════════════════════════════════════════════════════════
# OPENAI — AI Worker LLM Backend
# ═════════════════════════════════════════════════════════════════════════════

# OpenAI API key — required for the AI worker (LangGraph/LangChain reasoning).
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use for code review and reasoning tasks (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# OpenAI request timeout in seconds (default: 120)
# OPENAI_TIMEOUT=120

# LangSmith tracing (optional — for AI reasoning observability)
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=ls-your-langsmith-api-key-here
# LANGCHAIN_PROJECT=flowos


# ═════════════════════════════════════════════════════════════════════════════
# FLOWOS AGENT IDENTITY
# ═════════════════════════════════════════════════════════════════════════════

# Unique identifier for this agent instance.
# For human agents: use a stable UUID tied to the user account.
# For machine/AI workers: auto-generated or set per deployment.
# Generate with: python -c "import uuid; print(uuid.uuid4())"
FLOWOS_AGENT_ID=00000000-0000-0000-0000-000000000001

# Agent type: human | machine | ai | system
# Controls which Kafka consumer groups this agent joins and which tasks
# it is eligible to receive.
FLOWOS_AGENT_TYPE=human

# Human-readable display name for this agent (shown in the UI)
# FLOWOS_AGENT_NAME=Alice

# Agent workspace root directory (overrides APP_WORKSPACE_ROOT for this agent)
# FLOWOS_WORKSPACE=/home/alice/flowos-workspace


# ═════════════════════════════════════════════════════════════════════════════
# API SERVER
# ═════════════════════════════════════════════════════════════════════════════

# Port the FastAPI server listens on (default: 8000)
API_PORT=8000

# CORS allowed origins (comma-separated)
# API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ═════════════════════════════════════════════════════════════════════════════
# UI (React Frontend)
# ═════════════════════════════════════════════════════════════════════════════

# Port the UI nginx server listens on (default: 3000)
UI_PORT=3000

# API base URL used by the React frontend (injected at build time via Vite)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket base URL used by the React frontend
VITE_WS_BASE_URL=ws://localhost:8000


# ═════════════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═════════════════════════════════════════════════════════════════════════════

# Port for the Prometheus metrics endpoint (default: 9090)
METRICS_PORT=9090

# Enable Prometheus metrics collection (default: true)
METRICS_ENABLED=true


# ═════════════════════════════════════════════════════════════════════════════
# ARGO WORKFLOWS (Machine Worker — Kubernetes build execution)
# ═════════════════════════════════════════════════════════════════════════════

# Argo Workflows server URL (only required when running machine-worker)
# ARGO_SERVER_URL=http://argo-server:2746

# Kubernetes namespace where Argo Workflows is installed
# ARGO_NAMESPACE=argo

# Kubernetes service account for Argo workflow pods
# ARGO_SERVICE_ACCOUNT=argo-workflow


# ═════════════════════════════════════════════════════════════════════════════
# WORKER CONCURRENCY
# ═════════════════════════════════════════════════════════════════════════════

# Maximum number of concurrent build/test tasks for the machine worker
# WORKER_MAX_CONCURRENT_TASKS=4

# Maximum number of concurrent AI reasoning tasks for the AI worker
# AI_WORKER_MAX_CONCURRENT_TASKS=2
